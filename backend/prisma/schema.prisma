generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum InsightType {
  SLEEP_CORRELATION
  MEDICATION_CORRELATION
  DOW_PATTERN
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password_hash String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  entries  Entry[]
  insights Insight[]
}

model Entry {
  id         String   @id @default(uuid())
  userId     String
  date       DateTime @db.Date
  sleepHours Float?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  symptoms    Symptom[]
  medications Medication[]

  @@unique([userId, date])
}

model Symptom {
  id       String @id @default(uuid())
  entryId  String
  name     String
  severity Int

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
}

model Medication {
  id      String  @id @default(uuid())
  entryId String
  name    String
  taken   Boolean

  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
}

model Insight {
  id              String      @id @default(uuid())
  userId          String
  type            InsightType
  description     String
  confidenceScore Float
  createdAt       DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}
